{
    "enabled": true,
    "offline": true,
    "modelProvider": "ollama",
    "defaultModel": "deepseek-coder",
    "models": {
        "code": "deepseek-coder",
        "chat": "llama3",
        "embedding": "nomic-embed-text"
    },
    "sessionTimeout": 3600,
    "maxTokens": 4096,
    "temperature": 0.7,
    "sandbox": true,
    "allowedPaths": [
        "Projects/",
        "Experiments/",
        "Scripts/"
    ],
    "memory": {
        "enabled": true,
        "maxEntries": 10000,
        "embeddingDimension": 384
    }
}
