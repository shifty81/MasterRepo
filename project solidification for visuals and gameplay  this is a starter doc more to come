4. Drawing Rotation Gizmo
private void DrawRotationGizmo(Vector3 pos)
{
    float radius = 1.2f;

    // Draw circles around X/Y/Z axes
    DrawCircle(pos, Vector3.UnitX, radius, Color.Red);
    DrawCircle(pos, Vector3.UnitY, radius, Color.Green);
    DrawCircle(pos, Vector3.UnitZ, radius, Color.Blue);
}

private void DrawCircle(Vector3 center, Vector3 axis, float radius, Color color)
{
    int segments = 64;
    Vector3 prev = Vector3.Zero;
    for (int i = 0; i <= segments; i++)
    {
        float angle = i / (float)segments * MathF.PI * 2;
        Vector3 point = axis switch
        {
            var a when a == Vector3.UnitX => new Vector3(center.X, center.Y + MathF.Cos(angle) * radius, center.Z + MathF.Sin(angle) * radius),
            var a when a == Vector3.UnitY => new Vector3(center.X + MathF.Cos(angle) * radius, center.Y, center.Z + MathF.Sin(angle) * radius),
            _ => new Vector3(center.X + MathF.Cos(angle) * radius, center.Y + MathF.Sin(angle) * radius, center.Z)
        };
        if (i > 0) DrawLine(prev, point, color);
        prev = point;
    }
}
