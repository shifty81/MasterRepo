class ResourceComponent : public Component
{
public:
    ResourceType type;
    float amount = 100.0f;
    float hardness = 1.0f; // affects mining speed

    bool IsDepleted() const { return amount <= 0; }

    float Extract(float power)
    {
        float mined = power / hardness;
        mined = std::min(mined, amount);
        amount -= mined;
        return mined;
    }
};
