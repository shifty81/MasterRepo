// PlanetGenerator.h
class PlanetGenerator {
public:
    int resolution = 32; // Low-poly
    float radius = 100.0f;
    float noiseScale = 0.05f;
    float heightMultiplier = 10.0f;

    SceneObject* GeneratePlanet(glm::vec3 position){
        SceneObject* planet = new SceneObject();
        planet->position = position;

        Mesh* mesh = new Mesh();
        for(int y=0; y<=resolution; y++){
            for(int x=0; x<=resolution; x++){
                float theta = (float)x/resolution * 2.0f * 3.1415f;
                float phi = (float)y/resolution * 3.1415f;
                glm::vec3 pos = SphericalToCartesian(theta, phi, radius);
                pos += glm::normalize(pos) * PerlinNoise(theta*noiseScale, phi*noiseScale) * heightMultiplier;
                mesh->vertices.push_back(pos);
            }
        }
        planet->AddMesh(mesh);
        return planet;
    }

private:
    glm::vec3 SphericalToCartesian(float theta, float phi, float r){
        return glm::vec3(
            r * sin(phi)*cos(theta),
            r * cos(phi),
            r * sin(phi)*sin(theta)
        );
    }

    float PerlinNoise(float x, float y){
        return glm::perlin(glm::vec2(x,y));
    }
};
