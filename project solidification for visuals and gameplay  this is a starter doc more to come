private Vector3 RaycastTerrain(Point mousePos)
{
    // Convert mouse pos to world ray
    float ndcX = (float)(2*mousePos.X / Application.Current.MainWindow.ActualWidth -1);
    float ndcY = (float)(1-2*mousePos.Y / Application.Current.MainWindow.ActualHeight);

    Matrix invVP = Matrix.Invert(camera.GetViewMatrix()*projectionMatrix);
    Vector4 near = Vector4.Transform(new Vector4(ndcX, ndcY, 0,1), invVP);
    Vector4 far = Vector4.Transform(new Vector4(ndcX, ndcY, 1,1), invVP);
    near /= near.W; far/=far.W;

    Vector3 rayDir = Vector3.Normalize(new Vector3(far.X,far.Y,far.Z) - new Vector3(near.X,near.Y,near.Z));
    return TerrainInterop.RaycastTerrain(new Vector3(near.X,near.Y,near.Z), rayDir);
}
