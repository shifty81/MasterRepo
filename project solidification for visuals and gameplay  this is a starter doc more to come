    public void ToggleEditorMode()
    {
        EditorMode = !EditorMode;
        if(EditorMode) Mouse.OverrideCursor = Cursors.Arrow;
        else Mouse.OverrideCursor = Cursors.None;
    }

    // Mouse click for selection
    public void MouseClick_SelectObject(Point mousePos)
    {
        if(!EditorMode) return;

        float ndcX = (float)(2 * mousePos.X / Application.Current.MainWindow.ActualWidth - 1);
        float ndcY = (float)(1 - 2 * mousePos.Y / Application.Current.MainWindow.ActualHeight);

        Matrix invViewProj = Matrix.Invert(camera.GetViewMatrix() * projectionMatrix);

        Vector4 nearPoint = Vector4.Transform(new Vector4(ndcX, ndcY, 0, 1), invViewProj);
        Vector4 farPoint = Vector4.Transform(new Vector4(ndcX, ndcY, 1, 1), invViewProj);
        nearPoint /= nearPoint.W;
        farPoint /= farPoint.W;

        Vector3 rayOrigin = new Vector3(nearPoint.X, nearPoint.Y, nearPoint.Z);
        Vector3 rayDir = Vector3.Normalize(new Vector3(farPoint.X, farPoint.Y, farPoint.Z) - rayOrigin);

        // Call C++ backend raycast
