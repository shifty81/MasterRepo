        float u = ((float)rand()/RAND_MAX)*2.0f -1.0f;
        float theta = ((float)rand()/RAND_MAX) * 2.0f * 3.1415f;
        float r = cbrtf((float)rand()/RAND_MAX) * radius;
        return glm::vec3(r*sqrt(1-u*u)*cos(theta), r*sqrt(1-u*u)*sin(theta), r*u);
    }
};
