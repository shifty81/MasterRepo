        float x = (clip.X * 0.5f + 0.5f) * (float)Application.Current.MainWindow.ActualWidth;
        float y = (1 - (clip.Y * 0.5f + 0.5f)) * (float)Application.Current.MainWindow.ActualHeight;
        return new Vector2(x,y);
    }
