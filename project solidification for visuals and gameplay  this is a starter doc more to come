public void SculptTerrain(Vector3 worldPos)
{
    int minX = (int)(worldPos.X - brushRadius);
    int maxX = (int)(worldPos.X + brushRadius);
    int minZ = (int)(worldPos.Z - brushRadius);
    int maxZ = (int)(worldPos.Z + brushRadius);

    for(int x = minX; x <= maxX; x++)
    {
        for(int z = minZ; z <= maxZ; z++)
        {
            float dist = Vector2.Distance(new Vector2(x,z), new Vector2(worldPos.X, worldPos.Z));
            if(dist > brushRadius) continue;

            float effect = (1 - dist/brushRadius) * brushStrength;

            switch(currentTerrainTool)
            {
                case TerrainToolMode.Raise:
                    TerrainInterop.ModifyHeight(x,z,effect); break;
                case TerrainToolMode.Lower:
                    TerrainInterop.ModifyHeight(x,z,-effect); break;
                case TerrainToolMode.Smooth:
                    TerrainInterop.SmoothHeight(x,z,effect); break;
                case TerrainToolMode.Paint:
                    TerrainInterop.PaintBlock(x,z,paintBlockType); break;
                case TerrainToolMode.SpawnProps:
                    if(TerrainInterop.IsEmpty(x,z) && Random.Shared.NextFloat() < effect)
                        TerrainInterop.SpawnProp(x,z,propTypeToSpawn);
                    break;
            }
        }
    }
}
