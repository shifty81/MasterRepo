class NPC : public SceneObject
{
public:
    std::vector<glm::vec3> path;
    int currentTarget = 0;

    void Update(float dt)
    {
        if (path.empty()) return;

        glm::vec3 target = path[currentTarget];
        position += glm::normalize(target - position) * dt * 2.0f;

        if (glm::distance(position, target) < 0.1f)
            currentTarget++;
    }
};
