void ProcessInput(float dt){
    if(glfwGetKey(window, GLFW_KEY_SPACE) == GLFW_PRESS)
        TogglePlayMode(currentScene);

    // Example object selection
    if(glfwGetMouseButton(window, GLFW_MOUSE_BUTTON_LEFT) == GLFW_PRESS){
        selectedObject = PickObjectUnderCursor();
    }
}

// ---------------------------
// Main Loop
// ---------------------------
int main(){
    if(!InitOpenGL()) return -1;

    currentScene = new Scene();
    dockspace = new AtlasDockspace();
    commandManager = new CommandManager();

    // Setup default panels
    dockspace->root = new DockNode();
    dockspace->root->panel = new HierarchyPanel(currentScene);
    dockspace->root->childA = new DockNode();
    dockspace->root->childA->panel = new InspectorPanel(&selectedObject);
    dockspace->root->childB = new DockNode();
    dockspace->root->childB->panel = new ConsolePanel();

    float lastTime = glfwGetTime();
    while(!glfwWindowShouldClose(window)){
        float currentTime = glfwGetTime();
        float dt = currentTime - lastTime;
        lastTime = currentTime;

        ProcessInput(dt);

        if(currentMode == EngineMode::Play)
            UpdateScene(dt);

        RenderScene();
        RenderEditorGUI();

        glfwSwapBuffers(window);
        glfwPollEvents();
    }

    glfwDestroyWindow(window);
    glfwTerminate();
    return 0;
}

// ---------------------------
// Play Mode Toggle
