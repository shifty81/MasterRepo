class TraderComponent : public Component
{
public:
    std::unordered_map<ResourceType, float> buyPrices;
    std::unordered_map<ResourceType, float> sellPrices;

    void OpenShopUI()
    {
        UI::Open("Shop");
    }

    void Buy(ResourceType type, float amount, CargoComponent* playerCargo)
    {
        float price = buyPrices[type] * amount;

        if (Player::Credits >= price)
        {
            Player::Credits -= price;
            playerCargo->Add(type, amount);
        }
    }

    void Sell(ResourceType type, float amount, CargoComponent* playerCargo)
    {
        float price = sellPrices[type] * amount;

        if (playerCargo->cargo[type] >= amount)
        {
            playerCargo->cargo[type] -= amount;
            Player::Credits += price;
        }
    }
};
