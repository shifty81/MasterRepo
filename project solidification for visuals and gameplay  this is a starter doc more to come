🎛️ 3. Dockspace Manager
class AtlasDockspace
{
public:
    DockNode* root;

    void Draw()
    {
        DrawNode(root, 0, 0, screenWidth, screenHeight);
    }

private:
    void DrawNode(DockNode* node, int x, int y, int w, int h)
    {
        if (!node) return;

        if (node->split == DockNode::SplitDirection::None)
        {
            if (node->panel && node->panel->visible)
                node->panel->Draw();
            return;
        }

        if (node->split == DockNode::SplitDirection::Horizontal)
        {
            int hA = (int)(h * node->splitRatio);
            DrawNode(node->childA, x, y, w, hA);
            DrawNode(node->childB, x, y + hA, w, h - hA);
        }
        else
        {
            int wA = (int)(w * node->splitRatio);
            DrawNode(node->childA, x, y, wA, h);
            DrawNode(node->childB, x + wA, y, w - wA, h);
        }
    }
};
