class PowerComponent : public Component
{
public:
    float maxGeneration = 0.0f;
    float currentDemand = 0.0f;
    float availablePower = 0.0f;

    void ResetFrame()
    {
        currentDemand = 0.0f;
        availablePower = maxGeneration;
    }

    bool RequestPower(float amount)
    {
        if (availablePower >= amount)
        {
            availablePower -= amount;
            currentDemand += amount;
            return true;
        }
        return false;
    }
};
