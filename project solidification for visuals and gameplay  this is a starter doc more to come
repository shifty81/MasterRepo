#pragma once
#include "Mesh.h"
#include <glm/glm.hpp>
#include <random>
#include <cmath>

class ProceduralTerrain {
public:
    static Mesh Generate(int width, int depth, float scale, unsigned int seed) {
        Mesh mesh;
        std::mt19937 rng(seed);

        // Vertices
        for (int z = 0; z < depth; ++z) {
            for (int x = 0; x < width; ++x) {
                float height = PerlinNoise(x * 0.1f, z * 0.1f, rng) * scale;
                Vertex v;
                v.position = glm::vec3(x, height, z);
                v.color = glm::vec3(0.3f, 0.8f, 0.3f);
                v.normal = glm::vec3(0, 1, 0);
                mesh.vertices.push_back(v);
            }
        }

        // Indices
        for (int z = 0; z < depth - 1; ++z) {
            for (int x = 0; x < width - 1; ++x) {
                int topLeft = z * width + x;
                int topRight = topLeft + 1;
                int bottomLeft = (z + 1) * width + x;
                int bottomRight = bottomLeft + 1;

                mesh.indices.push_back(topLeft);
                mesh.indices.push_back(bottomLeft);
                mesh.indices.push_back(topRight);

                mesh.indices.push_back(topRight);
                mesh.indices.push_back(bottomLeft);
                mesh.indices.push_back(bottomRight);
            }
        }
        return mesh;
    }

private:
    static float PerlinNoise(float x, float z, std::mt19937& rng) {
        std::uniform_real_distribution<float> dist(0.0f, 0.5f);
        return std::sin(x) * std::cos(z) + dist(rng);
    }
};
