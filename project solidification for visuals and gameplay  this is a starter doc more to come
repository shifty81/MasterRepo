// FPSCamera.cs
using SharpDX;
using System;

public class FPSCamera
{
    public Vector3 Position;
    private float pitch = 0f; // up/down
    private float yaw = 0f;   // left/right

    public Vector3 Forward => Vector3.Normalize(new Vector3(
        (float)(Math.Cos(pitch) * Math.Sin(yaw)),
        (float)Math.Sin(pitch),
        (float)(Math.Cos(pitch) * Math.Cos(yaw))
    ));

    public Matrix GetViewMatrix()
    {
        return Matrix.LookAtLH(Position, Position + Forward, Vector3.UnitY);
    }

    public void Rotate(float deltaX, float deltaY)
    {
        float sensitivity = 0.002f;
        yaw += deltaX * sensitivity;
        pitch -= deltaY * sensitivity;
        pitch = MathUtil.Clamp(pitch, -MathUtil.PiOverTwo + 0.01f, MathUtil.PiOverTwo - 0.01f);
    }
}
