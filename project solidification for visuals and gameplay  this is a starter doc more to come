🎛️ 2️⃣ Slot System
struct ModuleSlot
{
    ModuleType allowedType;
    Module* installed = nullptr;
};

class ModuleComponent : public Component
{
public:
    std::vector<ModuleSlot> slots;

    bool InstallModule(int index, Module* module)
    {
        if (slots[index].allowedType != module->type)
            return false;

        if (slots[index].installed)
            slots[index].installed->OnRemove(owner);

        slots[index].installed = module;
        module->OnInstall(owner);

        return true;
    }

    void Update(float dt) override
    {
        for (auto& s : slots)
        {
            if (s.installed)
                s.installed->Update(owner, dt);
        }
    }
};
