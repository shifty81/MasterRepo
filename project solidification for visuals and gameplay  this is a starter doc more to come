class World {
public:
    std::map<std::tuple<int,int>, Chunk> chunks;
    unsigned int seed = 12345;

    Chunk& GetChunk(int chunkX, int chunkZ) {
        auto key = std::make_tuple(chunkX, chunkZ);
        if(chunks.find(key) == chunks.end()) {
            Chunk c;
            c.coord = {chunkX, chunkZ};
            c.mesh = ProceduralTerrain::Generate(16,16,2.0f, seed + chunkX*100 + chunkZ*100);
            c.props = GeneratePropsForChunk(chunkX, chunkZ);
            chunks[key] = c;
        }
        return chunks[key];
    }

    void GenerateChunksAround(float playerX, float playerZ, int radius=2){
        int cx = int(playerX/16);
        int cz = int(playerZ/16);
        for(int dx=-radius; dx<=radius; dx++)
            for(int dz=-radius; dz<=radius; dz++)
                GetChunk(cx+dx, cz+dz);
    }

private:
    std::vector<Prop> GeneratePropsForChunk(int chunkX,int chunkZ){
        std::vector<Prop> props;
        for(int i=0;i<10;i++){
            float x = float(rand()%16);
            float z = float(rand()%16);
            int type = i%2;
            props.push_back({glm::vec3(x,0,z), type});
        }
        return props;
    }
};

