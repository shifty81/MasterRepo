    atlasGUI->SliderInt("Station Modules", &stationGen.modules, 1, 20);
    if(atlasGUI->Button("Generate Station"))
        currentScene->Add(stationGen.GenerateStation({1000,0,0}));

    atlasGUI->EndPanel();
}

