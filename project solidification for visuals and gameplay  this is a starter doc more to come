void TogglePlayMode(Scene* scene){
    if(currentMode == EngineMode::Editor){
        SaveEditorState();
        currentMode = EngineMode::Play;
        StartGame(scene); // initialize AI, physics, etc.
    } else {
        StopGame();
        RestoreEditorState();
        currentMode = EngineMode::Editor;
    }
}

