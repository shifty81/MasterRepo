struct DockNode
{
    enum class SplitDirection { None, Horizontal, Vertical };

    SplitDirection split = SplitDirection::None;
    float splitRatio = 0.5f;

    DockNode* childA = nullptr;
    DockNode* childB = nullptr;

    Panel* panel = nullptr; // Leaf node
};
