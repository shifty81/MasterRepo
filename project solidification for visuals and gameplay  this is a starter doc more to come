// EngineDLL.cpp
extern "C" __declspec(dllexport)
Prop* RaycastProps(float rayOriginX, float rayOriginY, float rayOriginZ,
                   float rayDirX, float rayDirY, float rayDirZ, int* outCount)
{
    std::vector<Prop*> hits;
    for(auto& [key, chunk] : world.chunks){
        for(auto& prop : chunk.props){
            glm::vec3 propPos = prop.position;
            float radius = 0.5f;
            // Simple sphere collision
            glm::vec3 L = propPos - glm::vec3(rayOriginX, rayOriginY, rayOriginZ);
            if(glm::dot(L, L) < radius*radius) hits.push_back(&prop);
        }
    }
    *outCount = hits.size();
    return hits.empty() ? nullptr : hits[0];
}
