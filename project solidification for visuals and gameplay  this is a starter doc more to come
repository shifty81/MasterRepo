// DockNode.h
struct DockNode {
    enum class SplitDir { None, Horizontal, Vertical };
    SplitDir split = SplitDir::None;
    float splitRatio = 0.5f;
    DockNode* childA = nullptr;
    DockNode* childB = nullptr;
    class Panel* panel = nullptr;
};

// Panel.h
class Panel {
public:
    std::string name;
    bool visible = true;
    virtual void Draw() = 0;
};

// DockspaceManager.h
class AtlasDockspace {
public:
    DockNode* root;
    void Draw(int screenWidth, int screenHeight) {
        DrawNode(root, 0, 0, screenWidth, screenHeight);
    }

private:
    void DrawNode(DockNode* node, int x, int y, int w, int h) {
        if (!node) return;
        if (node->split == DockNode::SplitDir::None) {
            if (node->panel && node->panel->visible)
                node->panel->Draw();
            return;
        }
        if (node->split == DockNode::SplitDir::Horizontal) {
            int hA = int(h * node->splitRatio);
            DrawNode(node->childA, x, y, w, hA);
            DrawNode(node->childB, x, y + hA, w, h - hA);
        } else {
            int wA = int(w * node->splitRatio);
            DrawNode(node->childA, x, y, wA, h);
            DrawNode(node->childB, x + wA, y, w - wA, h);
        }
    }
};
