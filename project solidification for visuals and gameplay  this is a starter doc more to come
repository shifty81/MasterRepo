// TerrainChunk.h
#pragma once
#include "Mesh.h"
#include "ProceduralTerrain.h"
#include <glm/glm.hpp>
#include <map>
#include <tuple>

struct ChunkCoord { int x, z; };

struct Chunk {
    ChunkCoord coord;
    Mesh mesh;
};

class World {
public:
    std::map<std::tuple<int,int>, Chunk> chunks;

    Chunk& GetChunk(int chunkX, int chunkZ) {
        auto key = std::make_tuple(chunkX, chunkZ);
        if (chunks.find(key) == chunks.end()) {
            Chunk c;
            c.coord = {chunkX, chunkZ};
            c.mesh = ProceduralTerrain::Generate(16, 16, 2.0f, seed + chunkX*100 + chunkZ*100);
            chunks[key] = c;
        }
        return chunks[key];
    }

    void GenerateChunksAround(int playerX, int playerZ, int radius=2) {
        int chunkSize = 16;
        int centerX = playerX / chunkSize;
        int centerZ = playerZ / chunkSize;

        for(int dx=-radius; dx<=radius; dx++)
            for(int dz=-radius; dz<=radius; dz++)
                GetChunk(centerX+dx, centerZ+dz);
    }

private:
    unsigned int seed = 12345;
};
This automatically generates terrain around the player and caches the chunks in a map.

