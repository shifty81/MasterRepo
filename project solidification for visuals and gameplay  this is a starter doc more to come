void EditorGizmoManager::OnMouseMove(double mouseX, double mouseY) {
    if (!editorMode || !isDragging || selectedAxis == Axis::None) return;

    glm::vec3 delta((float)(mouseX - lastMousePos.x), (float)(mouseY - lastMousePos.y), 0.0f);

    switch (currentGizmo) {
    case GizmoMode::Move: DragMoveGroup(delta); break;
    case GizmoMode::Rotate: DragRotateGroup(delta); break;
    case GizmoMode::Scale: DragScaleGroup(delta); break;
    default: break;
    }

    lastMousePos = glm::dvec2(mouseX, mouseY);
}

// Gizmo transformations
void EditorGizmoManager::DragMoveGroup(const glm::vec3& delta) {
    glm::vec3 moveDelta = delta * 0.01f; // Adjust speed
    glm::vec3 gridSnap = glm::vec3(0.5f); // Example snap

    for (auto* p : selectedProps) {
        p->position += moveDelta;
        p->position = glm::round(p->position / gridSnap) * gridSnap;
    }
}

void EditorGizmoManager::DragRotateGroup(const glm::vec3& delta) {
    float angle = glm::length(delta) * 0.2f;
    glm::vec3 center = ComputeGroupCenter();

    for (auto* p : selectedProps) {
        glm::vec3 offset = p->position - center;
        glm::mat4 rot(1.0f);

        switch (selectedAxis) {
        case Axis::X: rot = glm::rotate(glm::mat4(1.0f), glm::radians(angle), glm::vec3(1,0,0)); break;
        case Axis::Y: rot = glm::rotate(glm::mat4(1.0f), glm::radians(angle), glm::vec3(0,1,0)); break;
        case Axis::Z: rot = glm::rotate(glm::mat4(1.0f), glm::radians(angle), glm::vec3(0,0,1)); break;
        default: break;
        }

        glm::vec3 newPos = center + glm::vec3(rot * glm::vec4(offset,1.0f));
        p->position = newPos;
    }
}

void EditorGizmoManager::DragScaleGroup(const glm::vec3& delta) {
    glm::vec3 center = ComputeGroupCenter();
    glm::vec3 scaleDelta = delta * 0.01f;

    for (auto* p : selectedProps) {
        glm::vec3 offset = p->position - center;
        glm::vec3 newOffset = offset * (1.0f + scaleDelta);
        p->position = center + newOffset;
        p->scale += scaleDelta;
    }
}

// Terrain sculpting
void EditorGizmoManager::SculptTerrain(const glm::vec3& worldPos) {
    int minX = (int)(worldPos.x - brushRadius);
    int maxX = (int)(worldPos.x + brushRadius);
    int minZ = (int)(worldPos.z - brushRadius);
    int maxZ = (int)(worldPos.z + brushRadius);

    for (int x = minX; x <= maxX; x++) {
        for (int z = minZ; z <= maxZ; z++) {
            float dist = glm::distance(glm::vec2(x,z), glm::vec2(worldPos.x,worldPos.z));
            if (dist > brushRadius) continue;
            float effect = (1.0f - dist/brushRadius) * brushStrength;

            switch(currentTerrainTool) {
            case TerrainToolMode::Raise: Terrain::ModifyHeight(x,z,effect); break;
            case TerrainToolMode::Lower: Terrain::ModifyHeight(x,z,-effect); break;
            case TerrainToolMode::Smooth: Terrain::SmoothHeight(x,z,effect); break;
            case TerrainToolMode::Paint: Terrain::PaintBlock(x,z,paintBlockType); break;
            case TerrainToolMode::SpawnProps:
                if (Terrain::IsEmpty(x,z) && ((float)rand()/RAND_MAX < effect))
                    Terrain::SpawnProp(x,z,propTypeToSpawn);
                break;
            default: break;
            }
        }
    }
}

