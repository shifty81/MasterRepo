🚀 Ship Controller
class ShipController : public Component
{
public:
    float thrust = 20.0f;
    float rotationSpeed = 2.0f;

    void Update(float dt) override
    {
        if (Input::Key(W)) owner->velocity += Forward() * thrust * dt;
        if (Input::Key(S)) owner->velocity -= Forward() * thrust * dt;

        if (Input::Key(A)) owner->rotation.y += rotationSpeed * dt;
        if (Input::Key(D)) owner->rotation.y -= rotationSpeed * dt;
    }

    glm::vec3 Forward()
    {
        return glm::vec3(
            sin(owner->rotation.y),
            0,
            cos(owner->rotation.y)
        );
    }
};
🎒 Cargo System
class CargoComponent : public Component
{
public:
    float capacity = 500.0f;
    std::unordered_map<ResourceType, float> cargo;

    float GetUsed()
    {
        float total = 0;
        for (auto& [k,v] : cargo) total += v;
        return total;
    }

    bool Add(ResourceType type, float amount)
    {
        if (GetUsed() + amount > capacity)
            return false;

        cargo[type] += amount;
        return true;
    }
};
