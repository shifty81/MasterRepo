glm::vec3 EditorGizmoManager::ComputeGroupCenter() {
    if (selectedProps.empty()) return glm::vec3(0.0f);
    glm::vec3 sum(0.0f);
    for (auto* p : selectedProps) sum += p->position;
    return sum / (float)selectedProps.size();
