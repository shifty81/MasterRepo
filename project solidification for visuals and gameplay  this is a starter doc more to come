class MiningComponent : public Component
{
public:
    float range = 100.0f;
    float power = 10.0f;

    SceneObject* currentTarget = nullptr;

    void Update(float dt) override
    {
        if (!Input::MouseDown(LEFT_MOUSE)) return;

        currentTarget = Raycast();

        if (!currentTarget) return;

        auto* resource = currentTarget->GetComponent<ResourceComponent>();
        if (!resource) return;

        float mined = resource->Extract(power * dt);

        Inventory::Get().Add(resource->type, mined);

        if (resource->IsDepleted())
            HandleDepletion(currentTarget);
    }

private:
    SceneObject* Raycast()
    {
        // Ray from camera forward → find closest object
        return Physics::Raycast(Camera::Position(), Camera::Forward(), range);
    }

    void HandleDepletion(SceneObject* obj)
    {
        // shrink, destroy, or replace with debris
        obj->Destroy();
    }
};
