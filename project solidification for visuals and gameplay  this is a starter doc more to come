using System;
using System.Runtime.InteropServices;
using System.Windows;
using System.Windows.Input;
using SharpDX;

public class EditorGizmoManager
{
    private FPSCamera camera;
    private Matrix projectionMatrix;
    private float gridSize = 0.5f;

    public bool EditorMode { get; private set; } = false;

    private Prop? selectedProp = null;
    private Vector3? selectedCharacter = null;

    private enum Axis { None, X, Y, Z }
    private Axis selectedAxis = Axis.None;

    private bool isDragging = false;
    private Point lastMousePos;

    public EditorGizmoManager(FPSCamera cam, Matrix proj)
    {
        camera = cam;
        projectionMatrix = proj;
    }

    #region Editor Mode Toggle
    public void ToggleEditorMode()
    {
        EditorMode = !EditorMode;
        Mouse.OverrideCursor = EditorMode ? Cursors.Arrow : Cursors.None;
        selectedProp = null;
        selectedAxis = Axis.None;
        isDragging = false;
    }
    #endregion

    #region Mouse Handling
    public void OnMouseDown(Point mousePos)
    {
        if (!EditorMode) return;

        // First check if clicking on gizmo axis
        if (selectedProp != null && TrySelectAxis(mousePos))
        {
            isDragging = true;
        }
        else
        {
            // Select prop
            SelectProp(mousePos);
        }

        lastMousePos = mousePos;
    }

    public void OnMouseUp(Point mousePos)
    {
        isDragging = false;
        selectedAxis = Axis.None;
    }

    public void OnMouseMove(Point mousePos)
    {
        if (isDragging && selectedProp != null && selectedAxis != Axis.None)
        {
            Vector3 mouseDelta = new Vector3((float)(mousePos.X - lastMousePos.X),
                                             (float)(mousePos.Y - lastMousePos.Y),
                                             0);

            DragSelectedProp(mouseDelta);
        }

        lastMousePos = mousePos;
    }
    #endregion

    #region Prop Selection
    private void SelectProp(Point mousePos)
    {
        float ndcX = (float)(2 * mousePos.X / Application.Current.MainWindow.ActualWidth - 1);
        float ndcY = (float)(1 - 2 * mousePos.Y / Application.Current.MainWindow.ActualHeight);

        Matrix invViewProj = Matrix.Invert(camera.GetViewMatrix() * projectionMatrix);
        Vector4 nearPoint = Vector4.Transform(new Vector4(ndcX, ndcY, 0, 1), invViewProj);
        Vector4 farPoint = Vector4.Transform(new Vector4(ndcX, ndcY, 1, 1), invViewProj);
        nearPoint /= nearPoint.W; farPoint /= farPoint.W;

        Vector3 rayOrigin = new Vector3(nearPoint.X, nearPoint.Y, nearPoint.Z);
        Vector3 rayDir = Vector3.Normalize(new Vector3(farPoint.X, farPoint.Y, farPoint.Z) - rayOrigin);

        int hitCount;
        IntPtr hitPropPtr = TerrainInterop.RaycastProps(rayOrigin.X, rayOrigin.Y, rayOrigin.Z,
                                                         rayDir.X, rayDir.Y, rayDir.Z, out hitCount);
        selectedProp = (hitCount > 0) ? Marshal.PtrToStructure<Prop>(hitPropPtr) : null;
    }
    #endregion

    #region Gizmo Selection & Dragging
    private bool TrySelectAxis(Point mousePos)
    {
        // Cast a small ray to detect axis boxes around prop
        // We'll use simple screen-space proximity (simpler than full 3D ray-box)
        Vector2 screenPos = WorldToScreen(selectedProp.Value.position);
        float gizmoSize = 20f; // pixels
        if (Math.Abs(mousePos.X - screenPos.X) < gizmoSize && Math.Abs(mousePos.Y - screenPos.Y) < gizmoSize)
        {
            // Determine axis based on relative position
            if (Math.Abs(mousePos.X - screenPos.X) > Math.Abs(mousePos.Y - screenPos.Y))
                selectedAxis = Axis.X;
            else
                selectedAxis = Axis.Y; // Simplified, Z-axis can use modifier key
            return true;
        }
        return false;
    }

    private void DragSelectedProp(Vector3 mouseDelta)
    {
        if (selectedProp == null) return;

        float moveAmount = mouseDelta.Length() * 0.05f; // sensitivity
        Vector3 newPos = selectedProp.Value.position;

        switch (selectedAxis)
        {
            case Axis.X: newPos.X += mouseDelta.X * 0.01f; break;
            case Axis.Y: newPos.Y -= mouseDelta.Y * 0.01f; break;
            case Axis.Z: newPos.Z += mouseDelta.Y * 0.01f; break;
        }

        // Grid snapping
        newPos.X = (float)Math.Round(newPos.X / gridSize) * gridSize;
        newPos.Y = (float)Math.Round(newPos.Y / gridSize) * gridSize;
        newPos.Z = (float)Math.Round(newPos.Z / gridSize) * gridSize;

        selectedProp = new Prop { position = newPos, type = selectedProp.Value.type };
        TerrainInterop.UpdateProp(selectedProp.Value);
    }
    #endregion

    #region Gizmo Rendering
    public void DrawGizmo()
    {
        if (!EditorMode || selectedProp == null) return;

        Vector3 pos = selectedProp.Value.position;
        float gizmoLength = 1.0f;

        DrawLine(pos, pos + new Vector3(gizmoLength, 0, 0), Color.Red);   // X
        DrawLine(pos, pos + new Vector3(0, gizmoLength, 0), Color.Green); // Y
        DrawLine(pos, pos + new Vector3(0, 0, gizmoLength), Color.Blue);  // Z
    }

    private void DrawLine(Vector3 start, Vector3 end, Color color)
    {
        // Implement SharpDX line drawing here (vertex buffer + draw)
    }

    private Vector2 WorldToScreen(Vector3 worldPos)
    {
        Matrix viewProj = camera.GetViewMatrix() * projectionMatrix;
        Vector4 clip = Vector4.Transform(new Vector4(worldPos, 1), viewProj);
        clip /= clip.W;

        float x = (clip.X * 0.5f + 0.5f) * (float)Application.Current.MainWindow.ActualWidth;
        float y = (1 - (clip.Y * 0.5f + 0.5f)) * (float)Application.Current.MainWindow.ActualHeight;
        return new Vector2(x, y);
    }
    #endregion

    #region Terrain Block Editing
    public void AddBlock(int chunkX, int chunkZ, int localX, int localZ, float height)
    {
        TerrainInterop.AddBlock(chunkX, chunkZ, localX, localZ, height);
    }

    public void RemoveBlock(int chunkX, int chunkZ, int localX, int localZ)
    {
        TerrainInterop.RemoveBlock(chunkX, chunkZ, localX, localZ);
    }
    #endregion

    #region Character Editing
    public void UpdateCharacterMovement(ref Vector3 characterPos)
    {
        if (!EditorMode || selectedCharacter == null) return;

        float speed = 0.1f;
        if (Keyboard.IsKeyDown(Key.W)) characterPos.Z += speed;
        if (Keyboard.IsKeyDown(Key.S)) characterPos.Z -= speed;
        if (Keyboard.IsKeyDown(Key.A)) characterPos.X -= speed;
        if (Keyboard.IsKeyDown(Key.D)) characterPos.X += speed;
    }
    #endregion
}
