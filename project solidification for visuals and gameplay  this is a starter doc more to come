// GravityComponent.h
class GravityComponent : public Component {
public:
    float mass = 1.0f;
    Scene* scene = nullptr;

    void Update(float dt) override {
        for(auto* obj : scene->objects){
            if(obj == owner) continue;
            GravityComponent* otherGravity = obj->GetComponent<GravityComponent>();
            if(!otherGravity) continue;

            glm::vec3 dir = obj->position - owner->position;
            float dist2 = glm::dot(dir, dir);
            if(dist2 < 0.0001f) continue;

            glm::vec3 force = dir * (mass * otherGravity->mass / dist2);
            owner->position += force * dt; // simplistic physics
        }
    }
};

// CollisionComponent.h
class CollisionComponent : public Component {
public:
    float radius = 1.0f;
    void Update(float dt) override {
        for(auto* obj : owner->scene->objects){
            if(obj == owner) continue;
            CollisionComponent* other = obj->GetComponent<CollisionComponent>();
            if(!other) continue;
            if(glm::distance(owner->position, obj->position) < radius + other->radius){
                ResolveCollision(owner, obj);
            }
        }
    }
};
