⚙️ 2️⃣ Ship Physics Core
class ShipPhysicsComponent : public Component
{
public:
    float mass = 100.0f;

    glm::vec3 velocity = {0,0,0};
    glm::vec3 angularVelocity = {0,0,0};

    std::vector<ThrusterBlock> thrusters;

    void Update(float dt) override
    {
        glm::vec3 totalForce(0);
        glm::vec3 totalTorque(0);

        for (auto& t : thrusters)
        {
            if (!IsThrusterActive(t)) continue;

            glm::vec3 worldDir = TransformDirection(t.direction);
            glm::vec3 force = worldDir * t.maxForce;

            totalForce += force;

            // Torque = r × F
            glm::vec3 r = TransformPosition(t.localPosition) - owner->position;
            glm::vec3 torque = glm::cross(r, force);

            totalTorque += torque;

            ConsumeFuel(t);
        }

        // Linear motion
        velocity += (totalForce / mass) * dt;
        owner->position += velocity * dt;

        // Angular motion
        angularVelocity += totalTorque * dt * 0.1f;
        owner->rotation += angularVelocity * dt;
    }
};
