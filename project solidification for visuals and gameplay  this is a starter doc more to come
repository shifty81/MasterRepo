private void MouseClick_SelectObject(Point mousePos)
{
    // Convert mousePos to NDC (-1..1)
    float ndcX = (float)(2 * mousePos.X / Viewport.ActualWidth - 1);
    float ndcY = (float)(1 - 2 * mousePos.Y / Viewport.ActualHeight);

    // Compute ray in world space
    Matrix invViewProj = Matrix.Invert(camera.GetViewMatrix() * projectionMatrix);
    Vector4 nearPoint = Vector4.Transform(new Vector4(ndcX, ndcY, 0, 1), invViewProj);
    Vector4 farPoint = Vector4.Transform(new Vector4(ndcX, ndcY, 1, 1), invViewProj);
    nearPoint /= nearPoint.W;
    farPoint /= farPoint.W;
    Vector3 rayDir = Vector3.Normalize(new Vector3(farPoint.X, farPoint.Y, farPoint.Z) - new Vector3(nearPoint.X, nearPoint.Y, nearPoint.Z));

    int hitCount;
    IntPtr hitProp = TerrainInterop.RaycastProps(nearPoint.X, nearPoint.Y, nearPoint.Z, rayDir.X, rayDir.Y, rayDir.Z, out hitCount);
    if(hitCount > 0){
        selectedProp = Marshal.PtrToStructure<Prop>(hitProp);
    }
