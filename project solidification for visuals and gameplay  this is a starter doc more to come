class Character {
public:
    glm::vec3 position;
    glm::vec3 velocity;
    float speed = 5.0f;
    float jumpForce = 5.0f;
    bool onGround = true;

    void Update(float deltaTime, const glm::vec3& inputDir) {
        glm::vec3 move = inputDir * speed * deltaTime;
        position += move;

        if (!onGround) velocity.y -= 9.81f * deltaTime;
        position += velocity * deltaTime;

        if (position.y < 0.0f) {
            position.y = 0.0f;
            onGround = true;
            velocity.y = 0.0f;
        }
    }

    void Jump() {
        if (onGround) { velocity.y = jumpForce; onGround = false; }
    }
};
