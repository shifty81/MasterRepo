<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <ProjectGuid>{4CAD6E7F-A8B9-6C3D-BE4F-5A6B7C8D9EAF}</ProjectGuid>
    <Keyword>MakeFileProj</Keyword>
    <RootNamespace>NovaForgeTests</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'" Label="Configuration">
    <ConfigurationType>Makefile</ConfigurationType>
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>Makefile</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <!-- Debug build + run tests (uses windows-x64-debug-tests preset) -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <NMakeBuildCommandLine>cd $(SolutionDir) &amp;&amp; cmake --preset windows-x64-debug-tests &amp;&amp; cmake --build Builds\windows-x64-debug-tests --target NFTests --config Debug</NMakeBuildCommandLine>
    <NMakeOutput>$(SolutionDir)Builds\windows-x64-debug-tests\bin\Debug\NFTests.exe</NMakeOutput>
    <NMakeCleanCommandLine>cd $(SolutionDir) &amp;&amp; cmake --build Builds\windows-x64-debug-tests --target NFTests --config Debug --clean-first</NMakeCleanCommandLine>
    <NMakeReBuildCommandLine>cd $(SolutionDir) &amp;&amp; cmake --preset windows-x64-debug-tests &amp;&amp; cmake --build Builds\windows-x64-debug-tests --target NFTests --config Debug --clean-first</NMakeReBuildCommandLine>
    <NMakePreprocessorDefinitions>_DEBUG;_WINDOWS;%(NMakePreprocessorDefinitions)</NMakePreprocessorDefinitions>
    <NMakeIncludeSearchPath>$(SolutionDir)Source;$(SolutionDir)Tests;$(SolutionDir)ThirdParty;%(NMakeIncludeSearchPath)</NMakeIncludeSearchPath>
  </PropertyGroup>

  <!-- Release build + run tests -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <NMakeBuildCommandLine>cd $(SolutionDir) &amp;&amp; cmake --preset windows-x64 -DNF_BUILD_TESTS=ON &amp;&amp; cmake --build Builds\windows-x64 --target NFTests --config Release</NMakeBuildCommandLine>
    <NMakeOutput>$(SolutionDir)Builds\windows-x64\bin\Release\NFTests.exe</NMakeOutput>
    <NMakeCleanCommandLine>cd $(SolutionDir) &amp;&amp; cmake --build Builds\windows-x64 --target NFTests --config Release --clean-first</NMakeCleanCommandLine>
    <NMakeReBuildCommandLine>cd $(SolutionDir) &amp;&amp; cmake --preset windows-x64 -DNF_BUILD_TESTS=ON &amp;&amp; cmake --build Builds\windows-x64 --target NFTests --config Release --clean-first</NMakeReBuildCommandLine>
    <NMakePreprocessorDefinitions>NDEBUG;_WINDOWS;%(NMakePreprocessorDefinitions)</NMakePreprocessorDefinitions>
    <NMakeIncludeSearchPath>$(SolutionDir)Source;$(SolutionDir)Tests;$(SolutionDir)ThirdParty;%(NMakeIncludeSearchPath)</NMakeIncludeSearchPath>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />

  <!-- Source files for browsing / IntelliSense -->
  <ItemGroup>
    <ClInclude Include="..\Source\**\*.h" />
  </ItemGroup>
  <ItemGroup>
    <ClCompile Include="..\Source\**\*.cpp" />
    <ClCompile Include="..\Tests\**\*.cpp" />
  </ItemGroup>

</Project>
